DATABASE_URL=sqlite+aiosqlite:///./academic_assistant.db
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# LLM Provider (auto = falls back from Gemini -> Groq -> Ollama -> mock)
LLM_PROVIDER=auto
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=

# CORS (comma-separated, e.g., https://site1.com,https://site2.com)
CORS_ORIGINS=

# Frontend URL (used for CORS)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ChromaDB (optional, falls back to in-memory)
CHROMA_HOST=localhost
CHROMA_PORT=8000
